                    <ui:VisualElement name="Item3" style="flex-grow: 0; border-top-width: 6px; border-right-width: 6px; border-bottom-width: 3px; border-left-width: 3px; border-left-color: rgb(55, 55, 55); border-right-color: rgb(55, 55, 55); border-top-color: rgb(55, 55, 55); border-bottom-color: rgb(55, 55, 55); background-color: rgba(55, 55, 55, 0.59); background-size: 60px 60px; width: 100px; height: 100px;"/>

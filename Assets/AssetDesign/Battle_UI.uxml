<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" editor-extension-mode="False">
    <ui:VisualElement style="flex-grow: 1; align-self: auto; align-items: stretch; justify-content: space-between; width: 100%; height: 20%;">
        <ui:VisualElement name="Top" style="flex-grow: 0; width: 100%; height: 15%; min-width: auto; min-height: auto; max-width: none; max-height: none; align-items: stretch; align-self: center; flex-direction: row; justify-content: space-between;">
            <ui:VisualElement name="LeftHP" style="flex-grow: 1; width: 40%;">
                <ui:ProgressBar value="10" title="" name="LPlayerHPBar" style="width: 100%; height: auto; font-size: 0; right: auto; left: auto; top: 25%; scale: -1 1; flex-direction: column; border-left-color: rgb(0, 0, 0); border-right-color: rgb(0, 0, 0); border-top-color: rgb(0, 0, 0); border-bottom-color: rgb(0, 0, 0); -unity-background-image-tint-color: rgba(3, 1, 1, 0.64); background-color: rgb(255, 255, 255); -unity-text-outline-width: 0; transform-origin: center; background-repeat: no-repeat no-repeat; align-items: stretch;"/>
                <ui:VisualElement name="LRoundWin" style="flex-grow: 0; top: 30%; left: 5%; width: 40%; height: 30%; flex-direction: row-reverse; justify-content: flex-end;">

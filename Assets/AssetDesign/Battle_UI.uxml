        <ui:VisualElement name="Middle" style="flex-grow: 1; width: 100%; height: 55%; min-width: auto; min-height: auto; max-width: none; max-height: none; align-items: stretch; justify-content: flex-end; -unity-text-outline-width: 0; background-color: rgba(0, 0, 0, 0); -unity-background-image-tint-color: rgba(255, 255, 255, 0.59);"/>
        <ui:VisualElement name="Bottom" style="flex-grow: 1; width: 30%; height: 31%; min-width: auto; min-height: auto; max-width: none; max-height: none; align-items: stretch; align-self: flex-start; position: relative; top: auto; bottom: 0; left: 0; flex-direction: row; align-content: flex-start; justify-content: flex-start; flex-wrap: nowrap;">
            <ui:VisualElement name="Left" style="flex-grow: 1; width: 40%; height: 100%;">

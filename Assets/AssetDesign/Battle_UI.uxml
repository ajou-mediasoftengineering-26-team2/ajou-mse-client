                    <ui:VisualElement name="Effect4" style="flex-grow: 0; background-color: rgba(55, 55, 55, 0.59); border-left-color: rgb(55, 55, 55); border-right-color: rgb(55, 55, 55); border-top-color: rgb(55, 55, 55); border-bottom-color: rgb(55, 55, 55); border-top-width: 3px; border-right-width: 3px; border-bottom-width: 1px; border-left-width: 2px; width: 50px; height: 50px;"/>
                </ui:VisualElement>
                <ui:VisualElement name="ElementalHand" style="flex-grow: 1; width: 100%; height: 70%; align-self: flex-end; justify-content: flex-start; align-items: center; align-content: flex-end;">
                    <ui:VisualElement name="Hand" style="flex-grow: 0; width: 200px; height: 200px; align-self: flex-end; align-content: center; justify-content: center; border-top-width: 6px; border-right-width: 3px; border-bottom-width: 6px; border-left-width: 6px; border-left-color: rgb(55, 55, 55); border-right-color: rgb(55, 55, 55); border-top-color: rgb(55, 55, 55); border-bottom-color: rgb(55, 55, 55); background-color: rgba(55, 55, 55, 0.51);"/>
                </ui:VisualElement>

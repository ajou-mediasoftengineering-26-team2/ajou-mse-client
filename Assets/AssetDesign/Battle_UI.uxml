                    <ui:VisualElement name="LWin2" style="flex-grow: 0; width: 18px; height: 18px; border-top-left-radius: 50%; border-left-width: 2px; border-bottom-left-radius: 50%; border-bottom-width: 2px; border-bottom-right-radius: 50%; border-right-width: 2px; border-top-right-radius: 50%; border-top-width: 2px; border-top-color: rgb(0, 0, 0); border-left-color: rgb(0, 0, 0); border-bottom-color: rgb(0, 0, 0); border-right-color: rgb(0, 0, 0); left: 5%; right: auto; flex-shrink: 0;"/>
                    <ui:VisualElement name="LWin3" style="flex-grow: 0; width: 18px; height: 18px; border-left-width: 2px; border-top-left-radius: 50%; border-top-width: 2px; border-right-width: 2px; border-bottom-left-radius: 50%; border-bottom-width: 2px; border-bottom-right-radius: 50%; border-top-right-radius: 50%; border-top-color: rgb(0, 0, 0); border-left-color: rgb(0, 0, 0); border-bottom-color: rgb(0, 0, 0); border-right-color: rgb(0, 0, 0); left: auto; right: auto; flex-shrink: 0;"/>
                </ui:VisualElement>
            </ui:VisualElement>
            <ui:VisualElement name="State" style="flex-grow: 0; width: 20%; -unity-text-align: upper-left;">
                <ui:VisualElement name="Timer" style="flex-grow: 1; width: 100%; height: 60%; align-self: center; -unity-text-align: middle-left;">
                    <ui:Label text="5" name="Time" data-source-path="" emoji-fallback-support="false" style="-unity-text-align: middle-center; height: 100%; font-size: 80px; -unity-font-style: bold; justify-content: flex-start; align-items: flex-start; width: auto; color: rgb(255, 223, 44); -unity-text-outline-color: rgb(89, 64, 155); -unity-text-outline-width: 3px; text-overflow: clip;"/>
                </ui:VisualElement>
                <ui:VisualElement name="Station" style="flex-grow: 1; width: auto; height: 30%;">
                    <ui:Label text="City Hall" name="CurrentStation" style="-unity-text-align: lower-center; font-size: 36px; color: rgb(56, 58, 140); -unity-text-outline-width: 1px; -unity-text-outline-color: rgb(42, 45, 149);"/>
                </ui:VisualElement>
            </ui:VisualElement>
            <ui:VisualElement name="RightHP" style="flex-grow: 0; width: 40%; flex-wrap: wrap-reverse;">

<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:VisualElement name="BackGround" style="flex-grow: 1; background-color: rgba(0, 0, 0, 0.86); justify-content: center; align-items: center;">
        <ui:VisualElement name="GameEnd" style="flex-grow: 0; width: 30%; align-self: center; height: 40%; justify-content: center; border-top-width: 10px; border-right-width: 10px; border-bottom-width: 10px; border-left-width: 10px; border-left-color: rgb(240, 200, 50); border-right-color: rgb(240, 200, 50); border-top-color: rgb(240, 200, 50); border-bottom-color: rgb(240, 200, 50); border-top-left-radius: 15px; border-top-right-radius: 15px; border-bottom-right-radius: 15px; border-bottom-left-radius: 15px; background-color: rgb(49, 49, 49);">
            <ui:VisualElement name="PlayerId" style="flex-grow: 1; flex-direction: row;">
                <ui:Label text="Label" name="VS"/>
                <ui:Label text="Label" name="Player1Id"/>
                <ui:Label text="Label" name="Player2Id"/>
            </ui:VisualElement>
            <ui:VisualElement name="GameScore" style="flex-grow: 1; flex-direction: row;">
                <ui:Label text="Label" name="Player1Score"/>

                <ui:Label text="Label" name="Player2Score"/>
            </ui:VisualElement>
        </ui:VisualElement>
        <ui:VisualElement name="Empty" style="flex-grow: 0; height: 2%;"/>
        <ui:Button text="HOME" name="HomeButton" style="align-items: stretch; width: 20%; height: 10%; border-top-left-radius: 15px; border-top-right-radius: 15px; border-bottom-right-radius: 15px; border-bottom-left-radius: 15px; font-size: 32px; -unity-font-style: bold; -unity-font-definition: url(&quot;project://database/Assets/Font/DungGeunMo.ttf?fileID=12800000&amp;guid=3ec608b729ff9514f880eda17091b1f1&amp;type=3#DungGeunMo&quot;); background-color: rgb(42, 42, 42); color: rgb(255, 255, 255); border-left-color: rgb(0, 0, 0); border-right-color: rgb(0, 0, 0); border-top-color: rgb(0, 0, 0); border-bottom-color: rgb(0, 0, 0);"/>
    </ui:VisualElement>
</ui:UXML>

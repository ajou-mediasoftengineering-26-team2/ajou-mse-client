<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:VisualElement picking-mode="Ignore" style="flex-grow: 1; width: 100%; height: 100%; align-self: center; justify-content: center;">
        <ui:Button text="" name="SettingButton" style="align-self: flex-start; align-items: center; justify-content: center; align-content: flex-end; flex-direction: column; aspect-ratio: 1; height: 30%; background-color: rgba(188, 188, 188, 0); border-top-width: 0; border-right-width: 0; border-bottom-width: 0; border-left-width: 0;">
            <ui:Image name="SettingImg" style="width: 100%; height: 100%; flex-grow: 1;"/>
        </ui:Button>
    </ui:VisualElement>
</ui:UXML>
